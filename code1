<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homebound Connect: Reinsertion Mission</title>
    <!-- Load Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Use Inter font family -->
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f7f7f7;
        }
        .card {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.06);
            transition: transform 0.2s ease-in-out;
        }
        .btn-primary {
            background-color: #22c55e;
            transition: background-color 0.2s;
        }
        .btn-primary:hover {
            background-color: #16a34a;
        }
    </style>
</head>
<body>

<div id="app" class="min-h-screen flex flex-col items-center">
    <!-- Header/Navigation -->
    <header class="w-full bg-white shadow-md p-4 sticky top-0 z-10">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-bold text-green-600">Homebound Connect</h1>
            <nav>
                <button onclick="changeView('mission')" class="text-gray-600 hover:text-green-600 font-medium px-3">Mission</button>
                <button onclick="changeView('dashboard')" class="text-gray-600 hover:text-green-600 font-medium px-3">My Impact</button>
                <!-- NEW: News button -->
                <button onclick="changeView('news')" class="text-gray-600 hover:text-green-600 font-medium px-3">Global News</button>
            </nav>
        </div>
    </header>

    <main class="w-full max-w-4xl p-4 md:p-8">

        <!-- Loading State -->
        <div id="loading-state" class="flex flex-col items-center justify-center p-20 text-gray-500">
            <svg class="animate-spin h-8 w-8 text-green-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <p class="mt-4">Initializing application and fetching data...</p>
        </div>

        <!-- Mission View -->
        <div id="mission-view" class="space-y-8 hidden">
            <!-- Global Stats -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="card p-6 bg-white rounded-xl text-center">
                    <p class="text-4xl font-extrabold text-green-600" id="total-migrants">0</p>
                    <p class="text-gray-500 mt-1">Reinserted to Date</p>
                </div>
                <div class="card p-6 bg-white rounded-xl text-center">
                    <p class="text-4xl font-extrabold text-green-600" id="active-campaigns">0</p>
                    <p class="text-gray-500 mt-1">Active Campaigns</p>
                </div>
                <div class="card p-6 bg-white rounded-xl text-center">
                    <p class="text-4xl font-extrabold text-green-600" id="total-donors">0</p>
                    <p class="text-gray-500 mt-1">Community Members</p>
                </div>
            </div>
            
            <!-- Mission Statement -->
            <section class="card p-6 bg-white rounded-xl">
                <h2 class="text-3xl font-bold text-gray-800 mb-4">Our Mission: Building a Better Africa</h2>
                <p class="text-gray-600 leading-relaxed">We believe in empowering African migrants to return home with dignity and purpose. Our app connects resources directly to specific reintegration projects, covering essential steps like vocational training, travel logistics, and securing local employment upon return.</p>
            </section>

            <!-- Active Campaigns Section -->
            <section>
                <h2 class="text-2xl font-bold text-gray-800 mb-4">Urgent Reinsertion Campaigns</h2>
                <div id="campaigns-list" class="space-y-4">
                    <!-- Campaigns loaded dynamically here -->
                </div>
            </section>
        </div>

        <!-- Donor Dashboard View -->
        <div id="dashboard-view" class="space-y-8 hidden">
            <h2 class="text-3xl font-bold text-gray-800">Your Personal Impact Dashboard</h2>
            <div class="card p-6 bg-white rounded-xl">
                <p class="text-sm font-medium text-gray-500">Your User ID (for collaboration):</p>
                <p id="user-id-display" class="break-all font-mono text-gray-700 mt-1"></p>
                <p class="mt-4 text-lg font-semibold text-green-600">Thank you for being part of the solution!</p>
            </div>

            <!-- Donation History -->
            <section class="card p-6 bg-white rounded-xl">
                <h3 class="text-xl font-semibold mb-4">Your Contribution History</h3>
                <div id="donation-history" class="space-y-3">
                    <p id="no-donations" class="text-gray-500">No donations recorded yet. Help us fund a campaign!</p>
                    <!-- Donations loaded dynamically here -->
                </div>
            </section>

            <!-- Mock Campaign Management (Simplified Admin Access) -->
            <button onclick="toggleAdminForm()" class="w-full btn-primary text-white p-3 rounded-lg font-semibold">
                New Campaign (Admin Use Demo)
            </button>
            <div id="admin-form-container" class="card p-6 bg-white rounded-xl hidden">
                <h3 class="text-xl font-semibold mb-4">Create New Campaign</h3>
                <form id="campaign-form" onsubmit="handleCampaignSubmit(event)">
                    <div class="mb-4">
                        <label for="campaign-title" class="block text-gray-700 text-sm font-bold mb-2">Title</label>
                        <input type="text" id="campaign-title" required class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                    </div>
                    <div class="mb-4">
                        <label for="campaign-goal" class="block text-gray-700 text-sm font-bold mb-2">Goal (People)</label>
                        <input type="number" id="campaign-goal" required class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                    </div>
                    <div class="mb-4">
                        <label for="campaign-description" class="block text-gray-700 text-sm font-bold mb-2">Description</label>
                        <textarea id="campaign-description" required class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500"></textarea>
                    </div>
                    <button type="submit" class="w-full btn-primary text-white p-3 rounded-lg font-semibold">
                        Launch Campaign
                    </button>
                </form>
            </div>
        </div>
        
        <!-- NEW: Global News View -->
        <div id="news-view" class="space-y-6 hidden">
            <h2 class="text-3xl font-bold text-gray-800">Latest Global Migration Updates</h2>
            <div id="news-loading" class="flex items-center justify-center p-10 bg-white rounded-xl card">
                <svg class="animate-spin h-6 w-6 text-green-500 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <p class="text-gray-600">Fetching latest news from reliable sources...</p>
            </div>
            <div id="news-results" class="space-y-4">
                <!-- News articles will be injected here -->
            </div>
        </div>

        <!-- Modal Placeholder -->
        <div id="modal-container" class="fixed inset-0 bg-gray-900 bg-opacity-75 hidden items-center justify-center p-4 z-20" onclick="hideModal(event)">
            <div id="modal-content" class="bg-white p-6 rounded-xl w-full max-w-sm card">
                <!-- Modal content loaded dynamically -->
            </div>
        </div>

    </main>

    <footer class="w-full p-4 text-center text-sm text-gray-500">
        © 2025 Homebound Connect. Reinsertion powered by community.
    </footer>

</div>

<script type="module">
    // --- Firebase Initialization and Imports ---
    import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
    import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
    import { getFirestore, doc, onSnapshot, collection, query, setDoc, addDoc, getDocs, updateDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";
    import { setLogLevel } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

    // Global variables (provided by Canvas environment)
    const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';
    const firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : {};
    const initialAuthToken = typeof __initial_auth_token !== 'undefined' ? __initial_auth_token : null;

    // Firebase instances
    let app, db, auth;
    let userId = null;
    let isAuthReady = false;
    setLogLevel('Debug');

    // Utility to get Firestore paths
    const getPublicCollectionRef = (collectionName) => collection(db, `artifacts/${appId}/public/data/${collectionName}`);
    const getUserCollectionRef = (collectionName) => collection(db, `artifacts/${appId}/users/${userId}/${collectionName}`);
    const getUserDocRef = (collectionName, docId) => doc(db, `artifacts/${appId}/users/${userId}/${collectionName}`, docId);

    // --- Core Application State & Auth Setup ---
    
    // Auth Listener and Initialization
    const initFirebase = async () => {
        try {
            app = initializeApp(firebaseConfig);
            db = getFirestore(app);
            auth = getAuth(app);
            
            document.getElementById('loading-state').classList.remove('hidden');

            onAuthStateChanged(auth, async (user) => {
                if (user) {
                    userId = user.uid;
                } else {
                    // Sign in either with custom token or anonymously
                    if (initialAuthToken) {
                        await signInWithCustomToken(auth, initialAuthToken);
                    } else {
                        await signInAnonymously(auth);
                    }
                    // Re-run onAuthStateChanged listener to set userId
                    return; 
                }

                // Auth is ready, proceed to load data and hide loading screen
                isAuthReady = true;
                document.getElementById('user-id-display').textContent = userId;
                document.getElementById('loading-state').classList.add('hidden');
                
                // Start real-time listeners for all necessary data
                setupRealtimeListeners();
                changeView('mission'); // Default view
            });

        } catch (error) {
            console.error("Firebase initialization failed:", error);
            document.getElementById('loading-state').innerHTML = `<p class="text-red-600">Error: Failed to connect to database. Check console for details.</p>`;
        }
    };

    // --- Real-Time Data Listeners ---

    const setupRealtimeListeners = () => {
        if (!isAuthReady) return;

        // 1. Listen for Campaigns (Public Data)
        const campaignsQuery = query(getPublicCollectionRef('campaigns'));
        onSnapshot(campaignsQuery, (snapshot) => {
            let totalMigrants = 0;
            const campaignsList = document.getElementById('campaigns-list');
            campaignsList.innerHTML = '';
            
            snapshot.forEach((doc) => {
                const campaign = doc.data();
                campaign.id = doc.id;
                totalMigrants += campaign.reinserted || 0;
                renderCampaignCard(campaign);
            });

            document.getElementById('total-migrants').textContent = totalMigrants.toLocaleString();
            document.getElementById('active-campaigns').textContent = snapshot.size;
        }, (error) => {
            console.error("Error fetching campaigns:", error);
        });

        // 2. Listen for User Donations (Private Data)
        const donationsQuery = query(getUserCollectionRef('donations'));
        onSnapshot(donationsQuery, (snapshot) => {
            const historyDiv = document.getElementById('donation-history');
            historyDiv.innerHTML = '';
            
            if (snapshot.empty) {
                historyDiv.innerHTML = `<p class="text-gray-500">No donations recorded yet. Help us fund a campaign!</p>`;
                return;
            }

            snapshot.forEach((doc) => {
                const donation = doc.data();
                renderDonationItem(donation);
            });
            document.getElementById('total-donors').textContent = (Math.ceil(Math.random() * 500) + 50).toLocaleString() + '+'; // Mock total donor count
        }, (error) => {
            console.error("Error fetching donations:", error);
        });
    };

    // --- Rendering Functions ---

    const renderCampaignCard = (campaign) => {
        const campaignsList = document.getElementById('campaigns-list');
        const percentage = campaign.goal > 0 ? Math.min(100, (campaign.reinserted / campaign.goal) * 100) : 0;
        
        const card = document.createElement('div');
        card.className = 'card p-5 bg-white rounded-xl border border-gray-100';
        card.innerHTML = `
            <h3 class="text-xl font-bold text-gray-800">${campaign.title}</h3>
            <p class="text-sm text-gray-500 mt-1">${campaign.description}</p>
            <div class="mt-4">
                <div class="flex justify-between text-sm font-medium mb-1">
                    <span class="text-green-600">${campaign.reinserted || 0} People Reinserted</span>
                    <span class="text-gray-500">${campaign.goal} Goal</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-2.5">
                    <div class="bg-green-500 h-2.5 rounded-full" style="width: ${percentage}%"></div>
                </div>
                <p class="text-xs text-gray-500 mt-2">${percentage.toFixed(0)}% of Reinsertion Goal Funded</p>
            </div>
            <button onclick="showDonationModal('${campaign.id}', '${campaign.title}')" class="mt-4 w-full btn-primary text-white p-2 rounded-lg font-semibold">
                Contribute & Track
            </button>
        `;
        campaignsList.appendChild(card);
    };

    const renderDonationItem = (donation) => {
        const historyDiv = document.getElementById('donation-history');
        const item = document.createElement('div');
        item.className = 'flex justify-between items-center p-3 bg-gray-50 rounded-lg';
        item.innerHTML = `
            <p class="font-medium text-gray-800">$${donation.amount.toFixed(2)}</p>
            <div class="text-right">
                <p class="text-sm text-gray-700 font-semibold">${donation.campaignTitle}</p>
                <p class="text-xs text-gray-500">on ${new Date(donation.timestamp.seconds * 1000).toLocaleDateString()}</p>
            </div>
        `;
        historyDiv.appendChild(item);
    };

    // --- View and Modal Handlers ---

    window.changeView = (viewId) => {
        document.getElementById('mission-view').classList.add('hidden');
        document.getElementById('dashboard-view').classList.add('hidden');
        document.getElementById('news-view').classList.add('hidden'); // NEW: Hide News

        if (viewId === 'mission') {
            document.getElementById('mission-view').classList.remove('hidden');
        } else if (viewId === 'dashboard') {
            document.getElementById('dashboard-view').classList.remove('hidden');
        } else if (viewId === 'news') {
            document.getElementById('news-view').classList.remove('hidden');
            fetchGlobalNews(); // NEW: Trigger news fetch when switching to this view
        }
    };

    window.showModal = (title, content, actionCallback) => {
        const modalContainer = document.getElementById('modal-container');
        const modalContent = document.getElementById('modal-content');
        modalContent.innerHTML = `
            <h3 class="text-2xl font-bold text-gray-800 mb-4">${title}</h3>
            <div id="modal-body">${content}</div>
            <div class="flex justify-end mt-6 space-x-3">
                <button onclick="document.getElementById('modal-container').classList.add('hidden')" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 font-semibold">Close</button>
                <button id="modal-action-btn" class="hidden px-4 py-2 btn-primary text-white rounded-lg font-semibold">Confirm</button>
            </div>
        `;
        // Only show 'Confirm' button if an action is provided
        if (actionCallback) {
            document.getElementById('modal-action-btn').classList.remove('hidden');
            document.getElementById('modal-action-btn').onclick = actionCallback;
        }
        modalContainer.classList.remove('hidden');
        modalContainer.classList.add('flex');
    };

    window.hideModal = (event) => {
        // Only hide if the click is on the container, not the content
        if (event.target.id === 'modal-container') {
            document.getElementById('modal-container').classList.add('hidden');
            document.getElementById('modal-container').classList.remove('flex');
        }
    }

    window.showDonationModal = (campaignId, campaignTitle) => {
        const modalContent = `
            <p class="text-gray-600 mb-4">You are supporting the <strong>${campaignTitle}</strong> campaign.</p>
            <div class="mb-4">
                <label for="donation-amount" class="block text-gray-700 text-sm font-bold mb-2">Donation Amount ($)</label>
                <input type="number" id="donation-amount" value="50" min="1" required class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
            </div>
        `;
        showModal('Make a Contribution', modalContent, () => handleDonation(campaignId, campaignTitle));
    };

    // --- Firebase Write Operations ---

    // 1. Handle New Campaign Creation (Admin Demo)
    window.handleCampaignSubmit = async (event) => {
        event.preventDefault();
        if (!isAuthReady) {
            console.error("Database not ready.");
            return;
        }

        const title = document.getElementById('campaign-title').value;
        const goal = parseInt(document.getElementById('campaign-goal').value);
        const description = document.getElementById('campaign-description').value;

        if (!title || !goal || !description) return;

        try {
            const newCampaign = {
                title: title,
                goal: goal,
                description: description,
                reinserted: 0, // Start at 0
                createdAt: new Date(),
                createdBy: userId
            };
            
            await addDoc(getPublicCo